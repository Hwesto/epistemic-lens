# Copy to apps/api/.env (loaded by the dev server) and/or export in your shell.
# The db:* scripts read $DATABASE_URL from the environment. Never commit secrets.
#
# Local dev:  docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:16
#             DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres
# Hosted:     use the Supabase/Neon connection string (egress must be allowed).

# Postgres (Supabase / Neon / Railway). Analysis layer connects read-only.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Web/admin client → API base (leave blank when served same-origin via proxy)
VITE_API_BASE=

# --- Auth (Supabase) ---------------------------------------------------------
# Server-side JWT verification (apps/api/src/auth.ts). Set SUPABASE_URL for JWKS
# verification and/or SUPABASE_JWT_SECRET for the legacy HS256 shared secret.
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_JWT_SECRET=
# Service role — ONLY used to delete the auth user on account deletion. Secret.
# SUPABASE_SERVICE_ROLE_KEY=
# Consent version recorded with each grant (bump to force re-consent).
CONSENT_VERSION=v1

# Browser clients (apps/web, apps/admin) — public anon key + project URL.
# VITE_SUPABASE_URL=https://<project>.supabase.co
# VITE_SUPABASE_ANON_KEY=

# Coverage rep target shown in the admin tool (apps/api/api/admin/coverage.ts)
# COVERAGE_TARGET_REPS=5

# In local dev the API server injects a `dev-user` (admin + consented via
# seed:dev), so the web and admin apps work without a real Supabase project.

# Offline pipeline only — NEVER used for live per-user generation
# ANTHROPIC_API_KEY=

# Email reminders (Resend)
# RESEND_API_KEY=
