# Copy to .env and fill in. Never commit real secrets.

# Postgres (Supabase / Neon / Railway). Analysis layer connects read-only.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Protects the admin import endpoint (apps/api/api/admin/import-story.ts)
ADMIN_TOKEN=change-me

# Web client → API base (leave blank when served same-origin)
VITE_API_BASE=

# Auth (Supabase / Clerk) — wire real JWT verification in apps/api/src/auth.ts
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Offline pipeline only — NEVER used for live per-user generation
# ANTHROPIC_API_KEY=

# Email reminders (Resend)
# RESEND_API_KEY=
