{
  "name": "daily-values-game",
  "private": true,
  "version": "0.1.0",
  "description": "Daily Values-Mirror Game — web-first PWA with an append-only, richly-tagged choice log feeding an offline factor-analysis loop.",
  "workspaces": [
    "apps/web",
    "apps/api",
    "apps/admin"
  ],
  "scripts": {
    "db:schema": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f db/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f db/seed/0001_framework_v1.sql -f db/seed/0002_framework_v2.sql",
    "db:migrate": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f db/migrations/0002_auth_consent.sql -f db/migrations/0003_defection_cni.sql -f db/migrations/0004_choice_position.sql -f db/migrations/0005_remembered_narration.sql",
    "db:reset": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -c 'drop schema public cascade; create schema public;' && npm run db:schema && npm run db:seed",
    "seed:dev": "npm --workspace @dvg/api run seed:dev",
    "dev:api": "npm --workspace @dvg/api run dev",
    "dev:web": "npm --workspace @dvg/web run dev",
    "dev:admin": "npm --workspace @dvg/admin run dev",
    "build:web": "npm --workspace @dvg/web run build",
    "build:admin": "npm --workspace @dvg/admin run build",
    "typecheck:api": "npm --workspace @dvg/api run typecheck",
    "db:bootstrap": "tsx scripts/deploy-setup.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/og": "^0.6.2",
    "jose": "^5.6.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "license": "UNLICENSED"
}
