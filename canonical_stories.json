{
  "_doc": "Canonical story-group patterns. Pinned by meta_version.json -> canonical_stories_hash. Adding a story = minor version bump. Changing patterns or excludes = major version bump (invalidates which articles past briefings would have grouped together).\n\nAs of meta_version 6.0.0 the base expands from 5 to 15+ entries: long-running geopolitical / economic / scientific dossiers that produce daily coverage across multiple buckets and therefore enable real longitudinal frame tracking under the closed Boydstun codebook. Dated short-lived stories (Hantavirus cruise, Vietnam-China visit, Ted Turner death) are retained for back-compatibility on prior briefings but the daily pipeline weights long-running dossiers higher.\n\nAuto-promoted candidates from analytical/auto_promote.py write to archive/auto_promoted_<date>.md for review. Promoting a candidate = manual edit of this file + minor pin bump.",
  "stories": {
    "hormuz_iran": {
      "title": "Strait of Hormuz / US-Iran deal",
      "patterns": [
        "\\bhormuz\\b",
        "\\bproject freedom\\b",
        "\\bepic fury\\b",
        "\\bone[\\- ]page memo\\b",
        "\\biran\\b.{0,40}\\bdeal\\b"
      ],
      "exclude": [],
      "tier": "long_running"
    },
    "turner_cnn": {
      "title": "Ted Turner death (CNN founder)",
      "patterns": [
        "\\bted turner\\b",
        "\\bturner.*\\bdies\\b",
        "\\bcnn founder\\b",
        "\\bcnn.*\\bturner\\b"
      ],
      "exclude": [],
      "tier": "dated"
    },
    "lebanon_buffer": {
      "title": "Israeli buffer zone in southern Lebanon",
      "patterns": [
        "\\bbuffer zone\\b",
        "\\bsouthern lebanon\\b",
        "\\blitani\\b",
        "\\bhezbollah\\b.*\\bisrael\\b",
        "\\bisraeli strikes\\b.*\\blebanon\\b"
      ],
      "exclude": [
        "\\bhormuz\\b"
      ],
      "tier": "long_running"
    },
    "hantavirus_cruise": {
      "title": "Hantavirus outbreak on MV Hondius",
      "patterns": [
        "\\bhantavirus\\b",
        "\\bmv hondius\\b",
        "\\bcruise.*\\bvirus\\b"
      ],
      "exclude": [],
      "tier": "dated"
    },
    "vietnam_china_visit": {
