{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "residual_clusters.schema.json",
  "title": "Residual Clusters (PR2 Phase C)",
  "description": "HDBSCAN clusters over articles the perception layer didn't assign to a canonical story for a given date. Written by pipeline/discover_residual.py. Walked by analytical/persistence_tracker.py to build cross-day lineages.",
  "type": "object",
  "required": ["meta_version", "date", "n_clusters", "clusters"],
  "properties": {
    "meta_version": { "type": "string" },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "n_clusters": { "type": "integer", "minimum": 0 },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "n_articles", "n_buckets",
                      "member_article_ids", "bucket_distribution", "top_tokens"],
        "properties": {
          "cluster_id": { "type": "integer", "minimum": 0 },
          "n_articles": { "type": "integer", "minimum": 1 },
          "n_buckets": { "type": "integer", "minimum": 1 },
          "member_article_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[0-9a-f]{12}$" }
          },
          "bucket_distribution": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          },
          "top_tokens": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 10
          },
          "centroid_dim": { "type": "integer", "minimum": 1 },
          "stability": {
            "type": ["number", "null"],
            "description": "HDBSCAN cluster_persistence_ if available."
          }
        }
      }
    }
  }
}
