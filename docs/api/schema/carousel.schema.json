{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-lens/api/schema/carousel.schema.json",
  "title": "Draft carousel (Instagram / LinkedIn / TikTok-still)",
  "description": "Slide-deck draft generated by the daily draft_carousel job. Frontend renders slides programmatically (template-driven SVG/PNG). Slide bodies should be <= 200 chars; the prompt enforces this.",
  "type": "object",
  "required": ["story_key", "date", "title", "slides"],
  "additionalProperties": false,
  "properties": {
    "meta_version": {
      "type": "string",
      "description": "Methodology pin version this draft was produced under (added by meta.stamp())."
    },
    "story_key": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "title": {
      "type": "string",
      "description": "Front-slide title (large)."
    },
    "subtitle": {
      "type": "string",
      "description": "Front-slide subtitle (smaller)."
    },
    "slides": {
      "type": "array",
      "minItems": 4,
      "maxItems": 10,
      "description": "Body slides between front and closing. Recommended 5-8.",
      "items": {
        "type": "object",
        "required": ["title", "body"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "Slide heading. Often the bucket/outlet name in a frame-matrix carousel."
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Slide body. Often a verbatim quote. Capped at 200 chars."
          },
          "source": {
            "type": "object",
            "required": ["bucket", "url"],
            "additionalProperties": false,
            "properties": {
              "bucket": {"type": "string"},
              "url": {"type": "string", "format": "uri"},
              "outlet": {"type": "string"}
            }
          },
          "kind": {
            "type": "string",
            "enum": ["frame", "quote", "stat", "silence", "paradox", "callout"],
            "description": "Hint for frontend templating."
          }
        }
      }
    },
    "closing": {
      "type": "string",
      "description": "Closing-slide CTA / signoff."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "string"
    }
  }
}
