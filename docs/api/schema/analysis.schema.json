{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-lens/api/schema/analysis.schema.json",
  "title": "Daily framing analysis (canonical, structured)",
  "description": "Per-story analytical output produced by the daily analyze pass. The canonical artifact: machine-parseable, schema-validated, citation-grounded. Markdown rendering for PR review is generated downstream by render_analysis_md.py.",
  "type": "object",
  "required": [
    "meta_version", "date", "story_key", "story_title",
    "n_buckets", "n_articles", "tldr", "frames",
    "isolation_top", "bottom_line", "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "meta_version": {
      "type": "string",
      "description": "Methodology pin version this analysis was produced under."
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "story_key": {
      "type": "string",
      "description": "Canonical story key matching briefings/<date>_<story_key>.json."
    },
    "story_title": {
      "type": "string"
    },
    "n_buckets": { "type": "integer", "minimum": 1 },
    "n_articles": { "type": "integer", "minimum": 1 },
    "tldr": {
      "type": "string",
      "minLength": 60,
      "description": "3-6 sentences. Lead with the most surprising finding in the corpus."
    },
    "event_summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 300,
      "description": "1-2 sentences. WHAT HAPPENED, factual only. No framing language, no editorial voice, no cross-outlet comparison. The story anchor for readers not already across the event. Optional for archived analyses (renderer falls back to tldr); required on go-forward per .claude/prompts/daily_analysis.md as of meta-v8.7.0."
    },
    "frames": {
      "type": "array",
      "minItems": 2,
      "maxItems": 12,
      "description": "Frames identified in the corpus. `frame_id` is drawn from the closed Boydstun/Card codebook (frames_codebook.json) so longitudinal aggregation is possible. `sub_frame` is an optional short tag for story-specific color (1-3 words, no full sentences).",
      "items": {
        "type": "object",
        "required": ["frame_id", "buckets", "evidence"],
        "additionalProperties": false,
        "properties": {
          "frame_id": {
            "type": "string",
            "enum": [
              "ECONOMIC",
              "CAPACITY_RESOURCES",
              "MORALITY",
              "FAIRNESS",
              "LEGALITY",
              "POLICY_PRESCRIPTION",
              "CRIME_PUNISHMENT",
              "SECURITY_DEFENSE",
              "HEALTH_SAFETY",
              "QUALITY_OF_LIFE",
              "CULTURAL",
              "PUBLIC_OPINION",
              "POLITICAL",
              "EXTERNAL_REGULATION",
              "OTHER"
            ],
            "description": "Required closed-taxonomy frame from frames_codebook.json. Use OTHER only when no other frame applies; pair with sub_frame."
          },
          "sub_frame": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40,
            "description": "Optional short tag (1-3 words, no full sentences) for story-specific color, e.g. 'energy contagion', 'sovereign reputation'. Human-readable; not used for longitudinal aggregation."
          },
          "buckets": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "Bucket keys (matching briefings/) that carry this frame."
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "description": "At least one verbatim quote per frame, citing a corpus entry by index.",
            "items": {
              "type": "object",
              "required": ["bucket", "quote", "signal_text_idx"],
              "additionalProperties": false,
              "properties": {
                "bucket": { "type": "string" },
                "outlet": { "type": "string" },
                "quote": {
                  "type": "string",
                  "description": "Verbatim from briefing.corpus[idx].signal_text. No paraphrase."
                },
                "signal_text_idx": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Index into briefing.corpus[]. Used by the citation linter to verify groundedness."
                }
              }
            }
          }
        }
      }
    },
    "isolation_top": {
      "type": "array",
      "maxItems": 8,
      "description": "Top-N most isolated buckets, copied verbatim from metrics.json. As of meta_version 7.0.0 the primary metric is LaBSE bucket-mean cosine on original signal_text (`mean_similarity`).",
      "items": {
        "type": "object",
        "required": ["bucket", "mean_similarity"],
        "additionalProperties": false,
        "properties": {
          "bucket": { "type": "string" },
          "mean_similarity": {
            "type": "number",
            "description": "LaBSE bucket-mean cosine from metrics.isolation."
          },
          "note": {
            "type": "string",
            "description": "One-line interpretation. Flag suspected language confounding when lexical highlights look like language artefacts."
          }
        }
      }
    },
    "exclusive_vocab_highlights": {
      "type": "array",
      "description": "Selected buckets where exclusive vocabulary is editorially significant.",
      "items": {
        "type": "object",
        "required": ["bucket", "terms"],
        "additionalProperties": false,
        "properties": {
          "bucket": { "type": "string" },
          "terms": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "what_it_reveals": { "type": "string" }
        }
      }
    },
    "paradox": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["a", "b", "joint_conclusion"],
          "additionalProperties": false,
          "properties": {
            "a": { "$ref": "#/$defs/paradox_side" },
            "b": { "$ref": "#/$defs/paradox_side" },
            "joint_conclusion": {
              "type": "string",
              "description": "Why opposing-bloc buckets converge. One sentence."
            }
          }
        }
      ]
    },
    "silences": {
      "type": "array",
      "description": "Buckets that should plausibly cover this story but didn't.",
      "items": {
        "type": "object",
        "required": ["bucket", "what_they_covered_instead"],
        "additionalProperties": false,
        "properties": {
          "bucket": { "type": "string" },
          "what_they_covered_instead": { "type": "string" }
        }
      }
    },
    "single_outlet_findings": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["outlet", "bucket", "finding"],
        "additionalProperties": false,
        "properties": {
          "outlet": { "type": "string" },
          "bucket": { "type": "string" },
          "finding": { "type": "string" },
          "signal_text_idx": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "bottom_line": {
      "type": "string",
      "minLength": 40,
      "description": "2-3 sentences restating the headline finding."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "string",
      "description": "Model identifier (e.g. claude-haiku-4-5-20251001)."
    }
  },
  "$defs": {
    "paradox_side": {
      "type": "object",
      "required": ["bucket", "outlet", "quote", "signal_text_idx"],
      "additionalProperties": false,
      "properties": {
        "bucket": { "type": "string" },
        "outlet": { "type": "string" },
        "quote": { "type": "string", "description": "Verbatim." },
        "signal_text_idx": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
