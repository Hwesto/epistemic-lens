{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-lens/api/schema/health.schema.json",
  "title": "Daily health snapshot",
  "description": "Per-day pipeline observability artifact. Written by pipeline.daily_health, consumed by the daily.yml job-summary step (rendered into $GITHUB_STEP_SUMMARY) and by pipeline.feed_rot_check (which aggregates last-7-day error/stub streaks). Field names here are the cross-stage hand-off contract — renaming any of them silently breaks downstream parsing.",
  "type": "object",
  "required": [
    "date", "n_feeds", "n_items", "n_errors", "n_stub_feeds",
    "n_slow_feeds", "errors", "stub_feeds", "slow_feeds",
    "items_per_bucket_now", "items_per_bucket_avg7", "bucket_alerts",
    "extraction_totals", "extraction_full_pct", "extraction_per_bucket"
  ],
  "additionalProperties": true,
  "properties": {
    "meta_version": {
      "type": "string",
      "description": "Methodology pin version this artifact was produced under (added by meta.stamp())."
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "n_feeds":      {"type": "integer", "minimum": 0},
    "n_items":      {"type": "integer", "minimum": 0},
    "n_errors":     {"type": "integer", "minimum": 0},
    "n_stub_feeds": {"type": "integer", "minimum": 0},
    "n_slow_feeds": {"type": "integer", "minimum": 0},
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bucket", "feed"],
        "additionalProperties": false,
        "properties": {
          "bucket": {"type": "string"},
          "feed":   {"type": "string"},
          "http":   {"type": ["integer", "null"]},
          "error":  {"type": ["string",  "null"]}
        }
      }
    },
    "stub_feeds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bucket", "feed", "stub_pct"],
        "additionalProperties": false,
        "properties": {
          "bucket":   {"type": "string"},
          "feed":     {"type": "string"},
          "stub_pct": {"type": "number", "minimum": 0, "maximum": 100}
        }
      }
    },
    "slow_feeds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bucket", "feed", "ms"],
        "additionalProperties": false,
        "properties": {
          "bucket": {"type": "string"},
          "feed":   {"type": "string"},
          "ms":     {"type": "integer", "minimum": 0}
        }
      }
    },
    "items_per_bucket_now": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "items_per_bucket_avg7": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": 0}
    },
    "bucket_alerts": {
      "type": "array",
      "description": "Heterogeneous union discriminated on `alert_type`.",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["bucket", "alert_type", "now", "avg7", "drop_pct"],
            "additionalProperties": false,
            "properties": {
              "bucket":     {"type": "string"},
              "alert_type": {"const": "volume_drop"},
              "now":        {"type": "integer", "minimum": 0},
              "avg7":       {"type": "number",  "minimum": 0},
              "drop_pct":   {"type": "number"}
            }
          },
          {
            "type": "object",
            "required": [
              "bucket", "alert_type", "attempted", "full",
              "full_pct", "errors", "none"
            ],
            "additionalProperties": false,
            "properties": {
              "bucket":     {"type": "string"},
              "alert_type": {"const": "low_extraction"},
              "attempted":  {"type": "integer", "minimum": 0},
              "full":       {"type": "integer", "minimum": 0},
              "full_pct":   {"type": "number",  "minimum": 0, "maximum": 100},
              "errors":     {"type": "integer", "minimum": 0},
              "none":       {"type": "integer", "minimum": 0}
            }
          }
        ]
      }
    },
    "extraction_totals": {
      "type": "object",
      "required": ["FULL", "PARTIAL", "STUB", "NONE", "ERROR", "SKIPPED"],
      "additionalProperties": false,
      "properties": {
        "FULL":    {"type": "integer", "minimum": 0},
        "PARTIAL": {"type": "integer", "minimum": 0},
        "STUB":    {"type": "integer", "minimum": 0},
        "NONE":    {"type": "integer", "minimum": 0},
        "ERROR":   {"type": "integer", "minimum": 0},
        "SKIPPED": {"type": "integer", "minimum": 0}
      }
    },
    "extraction_full_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "extraction_per_bucket": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "FULL":    {"type": "integer", "minimum": 0},
          "PARTIAL": {"type": "integer", "minimum": 0},
          "STUB":    {"type": "integer", "minimum": 0},
          "NONE":    {"type": "integer", "minimum": 0},
          "ERROR":   {"type": "integer", "minimum": 0},
          "SKIPPED": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
