{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "persistent_residual.schema.json",
  "title": "Persistent Residual Lineages (PR2 Phase C)",
  "description": "Cross-day lineages of residual clusters, linked by member-article-ID Jaccard overlap >=0.30. Written by analytical/persistence_tracker.py. Lineages with day_count >= 3 AND n_buckets_union >= 4 are promotion candidates surfaced by analytical/auto_promote.py.",
  "type": "object",
  "required": ["meta_version", "end_date", "window_days",
                "jaccard_threshold", "n_lineages", "lineages"],
  "properties": {
    "meta_version": { "type": "string" },
    "end_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "window_days": { "type": "integer", "minimum": 2 },
    "jaccard_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "n_lineages": { "type": "integer", "minimum": 0 },
    "lineages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lineage_id", "seed_date", "seed_cluster_id",
                      "latest_date", "latest_cluster_id",
                      "day_count", "n_buckets_union", "buckets_seen",
                      "latest_top_tokens", "latest_member_ids",
                      "consensus_tokens"],
        "properties": {
          "lineage_id": { "type": "string", "pattern": "^L[0-9a-f]+$" },
          "seed_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "seed_cluster_id": { "type": "integer" },
          "latest_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "latest_cluster_id": { "type": "integer" },
          "day_count": { "type": "integer", "minimum": 2 },
          "n_buckets_union": { "type": "integer", "minimum": 1 },
          "buckets_seen": { "type": "array", "items": { "type": "string" } },
          "latest_top_tokens": { "type": "array", "items": { "type": "string" } },
          "latest_member_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[0-9a-f]{12}$" }
          },
          "consensus_tokens": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
