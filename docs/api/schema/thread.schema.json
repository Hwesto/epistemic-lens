{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-lens/api/schema/thread.schema.json",
  "title": "Draft thread (X / Twitter / Threads / Bluesky)",
  "description": "Short-form chained-post draft generated by the daily draft_thread job. Each tweet's text should be <= 280 chars; the prompt enforces this, the schema does not.",
  "type": "object",
  "required": ["story_key", "date", "hook", "tweets"],
  "additionalProperties": false,
  "properties": {
    "story_key": {
      "type": "string",
      "description": "Canonical story identifier matching briefings/<date>_<story_key>.json."
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Story date in UTC, ISO format YYYY-MM-DD."
    },
    "hook": {
      "type": "string",
      "minLength": 1,
      "description": "Opening tweet. Recommended <= 240 chars to leave room for thread indicator."
    },
    "tweets": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "description": "Body tweets. Recommended <= 280 chars each.",
      "items": {
        "type": "object",
        "required": ["text"],
        "additionalProperties": false,
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "description": "Required for any tweet making a factual claim or quoting an outlet.",
            "items": {
              "type": "object",
              "required": ["bucket", "url"],
              "additionalProperties": false,
              "properties": {
                "bucket": {
                  "type": "string",
                  "description": "Bucket key from briefings/<date>_<story>.json (e.g. 'iran_opposition')."
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "outlet": {
                  "type": "string",
                  "description": "Optional human-readable outlet name."
                }
              }
            }
          }
        }
      }
    },
    "closing_cta": {
      "type": "string",
      "description": "Optional final tweet (link to long-form, or callout)."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "string",
      "description": "Model that generated this draft (e.g. 'claude-opus-4-7')."
    }
  }
}
