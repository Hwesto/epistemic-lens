{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-lens/api/schema/analysis.schema.json",
  "title": "Daily cluster framing analysis (v10)",
  "description": "Per-cluster analytical output produced by the daily analyze pass. v10: clusters replace canonical stories; outlets replace buckets as the atomic unit. The canonical artifact — machine-parseable, schema-validated, citation-grounded. Markdown rendering for review is generated downstream by publish/render/analysis_md.py.",
  "type": "object",
  "required": [
    "meta_version", "date", "lineage_id", "cluster_id", "cluster_name",
    "n_outlets", "n_countries", "tldr", "frames",
    "bottom_line", "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "meta_version": {
      "type": "string",
      "description": "Methodology pin version this analysis was produced under."
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "lineage_id": {
      "type": "string",
      "pattern": "^L[0-9a-f]+$",
      "description": "Stable cluster lineage identifier across days. Matches briefings/<DATE>_<lineage_id>.json."
    },
    "cluster_id": {
      "type": "integer",
      "description": "Day-local cluster index. Reassigned every day; lineage_id is the cross-day stable identifier."
    },
    "cluster_name": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "5-12 words, factual not editorial. Written by Claude during analysis. Examples: 'Ukraine drone strike on Moscow oil refinery', 'OpenAI lawsuit alleges training data theft'."
    },
    "salience_score": {
      "type": "number",
      "description": "Cluster salience score from core/cluster/salience.py."
    },
    "n_outlets": { "type": "integer", "minimum": 1 },
    "n_countries": { "type": "integer", "minimum": 1 },
    "n_articles": { "type": "integer", "minimum": 1 },
    "tldr": {
      "type": "string",
      "minLength": 60,
      "description": "3-6 sentences. Lead with the most surprising finding."
    },
    "event_summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 300,
      "description": "1-2 sentences. WHAT HAPPENED, factual only. No framing language, no editorial voice, no cross-outlet comparison."
    },
    "frames": {
      "type": "array",
      "minItems": 2,
      "maxItems": 12,
      "description": "Frames identified in the corpus. frame_id drawn from the closed Boydstun/Card codebook (core/config/frames_codebook.json).",
      "items": {
        "type": "object",
        "required": ["frame_id", "outlets", "countries", "evidence"],
        "additionalProperties": false,
        "properties": {
          "frame_id": {
            "type": "string",
            "enum": [
              "ECONOMIC", "CAPACITY_RESOURCES", "MORALITY", "FAIRNESS",
              "LEGALITY", "POLICY_PRESCRIPTION", "CRIME_PUNISHMENT",
              "SECURITY_DEFENSE", "HEALTH_SAFETY", "QUALITY_OF_LIFE",
              "CULTURAL", "PUBLIC_OPINION", "POLITICAL",
              "EXTERNAL_REGULATION", "OTHER"
            ]
          },
          "sub_frame": {
            "type": "string",
            "minLength": 2,
            "maxLength": 60,
            "description": "Optional 1-3 word cluster-specific colour."
          },
          "outlets": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "Outlet names carrying this frame."
          },
          "countries": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Country codes carrying this frame (derived from outlets but explicit for cross-country views)."
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["outlet", "quote", "signal_text_idx"],
              "additionalProperties": false,
              "properties": {
                "outlet":  { "type": "string" },
                "country": { "type": "string" },
                "quote":   { "type": "string", "description": "Verbatim from briefing.corpus[idx].signal_text." },
                "signal_text_idx": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "outlet_isolation_top": {
      "type": "array",
      "maxItems": 8,
      "description": "Top-N most isolated outlets within the cluster. v10 replacement for v9's bucket-level isolation.",
      "items": {
        "type": "object",
        "required": ["outlet", "mean_similarity"],
        "additionalProperties": false,
        "properties": {
          "outlet": { "type": "string" },
          "country": { "type": "string" },
          "mean_similarity": { "type": "number" },
          "note": { "type": "string" }
        }
      }
    },
    "outlet_exclusive_vocab_highlights": {
      "type": "array",
      "description": "Outlets where exclusive vocabulary is editorially significant.",
      "items": {
        "type": "object",
        "required": ["outlet", "terms"],
        "additionalProperties": false,
        "properties": {
          "outlet": { "type": "string" },
          "country": { "type": "string" },
          "terms": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "what_it_reveals": { "type": "string" }
        }
      }
    },
    "paradox": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["a", "b", "joint_conclusion"],
          "additionalProperties": false,
          "properties": {
            "a": { "$ref": "#/$defs/paradox_side" },
            "b": { "$ref": "#/$defs/paradox_side" },
            "joint_conclusion": {
              "type": "string",
              "description": "Why opposing-bloc outlets converge."
            }
          }
        }
      ]
    },
    "silences": {
      "type": "array",
      "description": "Countries that plausibly should cover this and DID carry items today on a different angle. For zero-item countries due to feed failure, use coverage_caveats[].",
      "items": {
        "type": "object",
        "required": ["country", "what_they_covered_instead"],
        "additionalProperties": false,
        "properties": {
          "country": { "type": "string" },
          "what_they_covered_instead": { "type": "string" }
        }
      }
    },
    "coverage_caveats": {
      "type": "array",
      "description": "Countries that contributed zero items today because every feed failed.",
      "items": {
        "type": "object",
        "required": ["country", "alert_type"],
        "additionalProperties": true,
        "properties": {
          "country": { "type": "string" },
          "alert_type": { "type": "string" },
          "avg7": { "type": "number" },
          "drop_pct": { "type": "number" },
          "now": { "type": "integer" },
          "reason": { "type": "string" }
        }
      }
    },
    "single_outlet_findings": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["outlet", "finding"],
        "additionalProperties": false,
        "properties": {
          "outlet": { "type": "string" },
          "country": { "type": "string" },
          "finding": { "type": "string" },
          "signal_text_idx": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "bottom_line": {
      "type": "string",
      "minLength": 40,
      "description": "2-3 sentences restating the headline finding."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "string",
      "description": "Model identifier (e.g. claude-sonnet-4-6)."
    }
  },
  "$defs": {
    "paradox_side": {
      "type": "object",
      "required": ["outlet", "quote", "signal_text_idx"],
      "additionalProperties": false,
      "properties": {
        "outlet": { "type": "string" },
        "country": { "type": "string" },
        "quote": { "type": "string", "description": "Verbatim." },
        "signal_text_idx": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
