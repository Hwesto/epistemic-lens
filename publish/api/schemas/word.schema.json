{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epistemic-lens/api/schema/word.schema.json",
  "title": "Within-language LLR / PMI per-bucket vocabulary",
  "description": "Shape of briefings/<DATE>_<story>_within_lang_llr.json and *_within_lang_pmi.json. Previously uncontracted; first formal schema as of meta-v8.7.0 (PR A+). Both files share the top-level envelope and `by_bucket` structure but differ in the per-bucket payload (LLR emits `distinctive_terms`, PMI emits `associations`).",
  "type": "object",
  "required": ["meta_version", "date", "story_key", "by_bucket", "n_languages", "method"],
  "additionalProperties": true,
  "properties": {
    "meta_version":  {"type": "string"},
    "date":          {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "story_key":     {"type": "string"},
    "story_title":   {"type": "string"},
    "n_languages":   {"type": "integer", "minimum": 0},
    "method":        {"type": "string", "enum": ["llr", "pmi", "log_odds_with_prior"]},
    "params":        {"type": "object"},
    "by_bucket": {
      "type": "object",
      "description": "bucket -> per-bucket payload. Required fields vary by method.",
      "additionalProperties": {
        "type": "object",
        "required": ["lang", "n_buckets_in_lang_cohort"],
        "properties": {
          "lang":                     {"type": "string"},
          "n_buckets_in_lang_cohort": {"type": "integer", "minimum": 0},
          "n_tokens_in_bucket":       {"type": "integer"},
          "n_tokens_in_cohort":       {"type": "integer"},
          "n_bigrams_in_bucket":      {"type": "integer"},
          "n_bigrams_in_cohort":      {"type": "integer"},
          "distinctive_terms": {
            "type": "array",
            "description": "Emitted by within_language_llr.",
            "items": {
              "type": "object",
              "required": ["term", "llr"],
              "properties": {
                "term":            {"type": "string"},
                "count_in_bucket": {"type": "integer"},
                "count_in_cohort": {"type": "integer"},
                "rate_in_bucket":  {"type": "number"},
                "rate_in_cohort":  {"type": "number"},
                "llr":             {"type": "number"},
                "log_ratio":       {"type": ["number", "null"]},
                "p_value":         {"type": ["number", "null"]}
              }
            }
          },
          "associations": {
            "type": "array",
            "description": "Emitted by within_language_pmi.",
            "items": {
              "type": "object",
              "required": ["bigram", "z_score"],
              "properties": {
                "bigram": {
                  "type": "array",
                  "items": {"type": "string"},
                  "minItems": 2,
                  "maxItems": 2
                },
                "count_in_bucket": {"type": "integer"},
                "count_in_cohort": {"type": "integer"},
                "log_odds":        {"type": "number"},
                "z_score":         {"type": "number"},
                "lift":            {"type": ["number", "null"]},
                "rate_in_bucket":  {"type": "number"},
                "rate_in_cohort":  {"type": "number"}
              }
            }
          }
        }
      }
    }
  }
}
