e2e_test/
fresh_pull/
__pycache__/
*.pyc

# Public API tree — derivative of briefings/+analyses/+drafts/.
# Regenerated fresh by build_index.py in the cron and deployed to
# GitHub Pages as a build artifact. Never committed.
# Leading slash anchors to the repo root so docs/api/schema/ is not
# also ignored by this rule.
/api/

# Defense in depth — secrets must never enter the repo.
.env
.env.*
*.token
secrets/
videos/*.mov
# Keep videos/stills/ + videos/*.mp4 in repo for review.
# (Each MP4 is ~10-30 MB; OK at our daily volume. Switch to git-lfs
# if/when the videos directory exceeds ~500 MB.)

# TTS voice models — too big for git, regen via synthesize_voiceover.py
video/public/voices/*.onnx
video/public/voices/*.onnx.json
video/public/voices/voices.bin
video/public/voices/kokoro-*.onnx

# Per-render voiceover WAVs — regen on demand
video/public/voiceovers/

# source_audit.py output — regenerated fresh on demand.
source_audit.json
